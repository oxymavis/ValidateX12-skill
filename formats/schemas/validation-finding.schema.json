{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/edi-validate-studio/validation-finding.schema.json",
  "title": "ValidationFinding",
  "description": "API JSON uses camelCase for some fields (messageZh, messageEn, pointId, rawSegment, rawSegmentIndex).",
  "oneOf": [
    {
      "type": "object",
      "title": "Snake_case (internal)",
      "required": ["code", "severity", "segment", "element", "message_zh", "message_en", "source"],
      "properties": {
        "code": { "type": "string" },
        "severity": { "type": "string" },
        "segment": { "type": "string" },
        "element": { "type": "string" },
        "message_zh": { "type": "string" },
        "message_en": { "type": "string" },
        "source": { "type": "string" },
        "point_id": { "type": "string", "default": "" },
        "raw_segment": { "type": "string", "default": "" },
        "raw_segment_index": { "type": "integer", "default": 0 }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "title": "camelCase (HTTP JSON)",
      "required": ["code", "severity", "segment", "element", "messageZh", "messageEn", "source"],
      "properties": {
        "code": { "type": "string" },
        "severity": { "type": "string" },
        "segment": { "type": "string" },
        "element": { "type": "string" },
        "messageZh": { "type": "string" },
        "messageEn": { "type": "string" },
        "source": { "type": "string" },
        "pointId": { "type": "string" },
        "rawSegment": { "type": "string" },
        "rawSegmentIndex": { "type": "integer" }
      },
      "additionalProperties": true
    }
  ]
}
